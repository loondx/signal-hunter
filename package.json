{
  "name": "signal-hunter",
  "version": "0.1.0",
  "description": "AI agent that hunts buying signals across the internet for freelancers and service businesses",
  "type": "module",
  "bin": {
    "signal-hunter": "./bin/cli.js",
    "signal-hunter-mcp": "./src/mcp-server.js"
  },
  "scripts": {
    "setup": "node src/commands/setup.js",
    "doctor": "node src/commands/doctor.js",
    "scan": "node src/commands/scan.js",
    "list": "node src/commands/list.js",
    "cron": "node src/daemon.js",
    "mcp": "node src/mcp-server.js",
    "start": "node src/daemon.js",
    "update": "node src/commands/update.js",
    "version": "node bin/cli.js version"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "sources/",
    "integrations/",
    "utils/",
    "config/*.example.yml",
    "data/.gitkeep",
    ".env.example",
    "README.md",
    "install.sh",
    "uninstall.sh"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai-agent",
    "lead-generation",
    "signal-detection",
    "freelance",
    "mcp",
    "buying-signals",
    "business-development",
    "open-source"
  ],
  "author": "Pankaj Kumar <pankajkumar.techie@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loondx/signal-hunter.git"
  },
  "homepage": "https://github.com/loondx/signal-hunter#readme",
  "bugs": {
    "url": "https://github.com/loondx/signal-hunter/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^4.2.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
